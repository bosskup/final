local function setBtnState(btn, state, activeGradColors, inactiveGradColors)
    local grad = btn:FindFirstChild("UIGradient") or Instance.new("UIGradient", btn)
    if state then
        grad.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, activeGradColors[1]),
            ColorSequenceKeypoint.new(1, activeGradColors[2])
        }
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        grad.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, inactiveGradColors[1]),
            ColorSequenceKeypoint.new(1, inactiveGradColors[2])
        }
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end

