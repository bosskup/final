local function updateSlider(input)
    if not draggingSlider then return end
    local slideX = math.clamp(input.Position.X - speedSliderBg.AbsolutePosition.X, 0, speedSliderBg.AbsoluteSize.X)
    local percentage = slideX / speedSliderBg.AbsoluteSize.X
    speedSliderFill.Size = UDim2.new(percentage, 0, 1, 0)
    
    SpeedValue = math.floor(16 + ((300 - 16) * percentage))
    if SpeedValue <= 16 then 
        SpeedValue = 16 
        SpeedEnabled = false
    else
        SpeedEnabled = true
    end
    speedLabel.Text = "⚡ WalkSpeed: " .. SpeedValue
end

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        updateSlider(input)
    end
end)


