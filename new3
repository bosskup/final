local function teleportElCapo()
    local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local targetPrompt = workspace:WaitForChild("ElCapoSpawnTeleport", 3) and workspace.ElCapoSpawnTeleport:WaitForChild("HumanoidRootPart", 3):WaitForChild("ElCapoSpawnTeleportPrompt", 3)
    
    if targetPrompt and myHrp then
        local targetPart = targetPrompt.Parent
        if targetPart and targetPart:IsA("BasePart") then
            myHrp.CFrame = targetPart.CFrame * CFrame.new(0, 1, 0)
            task.wait(0.2)
            if fireproximityprompt then fireproximityprompt(targetPrompt) end
        end
    end
end

local function teleportTunnel(promptName)
    local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local targetParent = workspace:FindFirstChild("Tunnel") and workspace.Tunnel:FindFirstChild(promptName)
    local targetPrompt = targetParent and targetParent:FindFirstChild("TunnelExitProximityPrompt")
    
    if targetParent and targetPrompt and myHrp then
        local lookPos = targetParent.Position
        local myPos = myHrp.Position
        
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, lookPos)
        myHrp.CFrame = CFrame.new(myPos, Vector3.new(lookPos.X, myPos.Y, lookPos.Z))
        task.wait(0.1)
        myHrp.CFrame = targetParent.CFrame * CFrame.new(0, 1, 0)
        myHrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        task.wait(0.2)
        if fireproximityprompt then fireproximityprompt(targetPrompt) end
    end
end

local function teleportEnterApt()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    pcall(function()
        local remote = ReplicatedStorage.__remotes.ApartmentService.TeleportFromApartmentCircle
        root.CFrame = CFrame.new(-217.3, 17.1, 190.6)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        task.wait(0.1)
        for i = 1, 5 do 
            task.spawn(function() remote:InvokeServer("Enter") end)
            task.wait(0.05) 
        end
    end)
end

local function teleportExitApt()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    pcall(function()
        root.CFrame = CFrame.new(1152.2, -83.8, -6029.0)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        task.wait(0.1)
        ReplicatedStorage.__remotes.ApartmentService.GetApartmentCircleTeleportDestination:InvokeServer("Exit")
        ReplicatedStorage.__remotes.ApartmentService.TeleportFromApartmentCircle:InvokeServer("Exit")
    end)
end

