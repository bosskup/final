local function isPolice(targetPlayer)
    if not targetPlayer or targetPlayer == player then return false end
    local backpack = targetPlayer:FindFirstChild("Backpack")
    local char = targetPlayer.Character
    if (backpack and (backpack:FindFirstChild("Taser") or backpack:FindFirstChild("Handcuffs"))) or
       (char and (char:FindFirstChild("Taser") or char:FindFirstChild("Handcuffs"))) then
        return true
    end
    return false
end

local function isWanted(targetPlayer)
    if targetPlayer == player then return false end
    if not targetPlayer.Character then return false end
    local hrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local wantedStatus = false
    pcall(function()
        local nametag = hrp:FindFirstChild("NametagGui")
        if nametag then
            local stars = nametag:FindFirstChild("WantedStars")
            if stars then
                wantedStatus = true
                if stars:IsA("GuiObject") and stars.Visible == false then
                    wantedStatus = false
                end
            end
        end
    end)
    return wantedStatus
end

local function isValidTarget(p)
    if TargetMode == "Police" then
        return isPolice(p)
    elseif TargetMode == "Wanted" then
        return isWanted(p)
    end
    return false
end

local function getClosestTarget()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local myPos = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.HumanoidRootPart.Position

    if not myPos then return nil end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and isValidTarget(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
            if p.Character.Humanoid.Health > 0 then
                local hrp = p.Character.HumanoidRootPart
                local distance = (hrp.Position - myPos).Magnitude
                if distance < shortestDistance then
                    closestPlayer = p
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

local function getPlayerMoney(targetPlayer)
    local moneyValue = 0
    pcall(function()
        local stats = targetPlayer:FindFirstChild("ReplicatedStats")
        local money = stats and stats:FindFirstChild("Money")
        if money then moneyValue = money.Value end
        pcall(function() moneyValue = targetPlayer.ReplicatedStats.Money.Value end)
    end)
    return moneyValue
end

