local function triggerArrest()
    local target = _G.LockedTarget or getClosestWantedPlayer()
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local char = game.Players.LocalPlayer.Character
        local myRoot = char and char:FindFirstChild("HumanoidRootPart")
        local targetRoot = target.Character.HumanoidRootPart
        if not myRoot then return end
        
        local distance = (myRoot.Position - targetRoot.Position).Magnitude
        if distance <= 30 then myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 2.5) end
        
        local humanoid = char:FindFirstChild("Humanoid")
        local backpack = game.Players.LocalPlayer:FindFirstChild("Backpack")
        local handcuffs = backpack and backpack:FindFirstChild("Handcuffs")
        local equippedHandcuffs = char:FindFirstChild("Handcuffs")
        
        if handcuffs and humanoid then humanoid:EquipTool(handcuffs)
        elseif not equippedHandcuffs then return end
        
        task.wait(0.2) 
        pcall(function() 
            local args = { target }
            ReplicatedStorage:WaitForChild("__remotes"):WaitForChild("Handcuffs"):WaitForChild("Detain"):InvokeServer(unpack(args)) 
        end)
    end
end
local function triggerKickDoor()
    local myChar = player.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if not myRoot then 
        warn("❌ ไม่พบตัวละครของคุณ (รอให้ตัวละครโหลดเสร็จก่อน)")
        return 
    end
    
    -- 1. เข้าถึงโฟลเดอร์ประตูโดยตรง
    local apartments = workspace:FindFirstChild("Apartments")
    local doorsFolder = apartments and apartments:FindFirstChild("Doors")
    
    if not doorsFolder then
        warn("❌ ไม่พบโฟลเดอร์ประตูในด่านนี้")
        return
    end
    
    local targetDoor = nil
    local closestDist = 12 -- ระยะการเตะ (12 Studs) ต้องไปยืนจ่อหน้าประตูเท่านั้น
    
    -- 2. สแกนหาประตูที่อยู่ใกล้ตัวที่สุด (ทดแทนการใช้เมาส์ชี้แบบ PC)
    for _, door in pairs(doorsFolder:GetChildren()) do
        if door:IsA("Model") or door:IsA("BasePart") then
            -- ดึงตำแหน่งพิกัดของประตู
            local doorPos = door:IsA("Model") and (door.PrimaryPart and door.PrimaryPart.Position or door:GetPivot().Position) or door.Position
            local dist = (doorPos - myRoot.Position).Magnitude
            
            if dist < closestDist then
                closestDist = dist
                targetDoor = door
            end
        end
    end
    
    -- 3. ถ้าระยะผ่าน และเจอประตู จะรันคำสั่งแบบ PC ทันที
    if targetDoor then
        -- เคลียร์มือกันบั๊กอนิเมชั่นค้าง
        local hum = myChar:FindFirstChildOfClass("Humanoid")
        if hum then hum:UnequipTools() end
        task.wait(0.1)
        
        -- ลอจิกการส่ง Remote ของ PC (ยิงสแปมรัวๆ)
        task.spawn(function()
            -- ส่ง Remote แจ้งเซิร์ฟเวอร์ว่าจะเริ่มเตะ
            pcall(function()
                ReplicatedStorage:WaitForChild("__remotes"):WaitForChild("ApartmentService"):WaitForChild("StartApartmentForceEntry"):InvokeServer(targetDoor)
            end)
            
            task.wait(0.1)
            
            -- ส่ง Remote สแปมเตะ 15 ครั้งรัวๆ ภายใน 1.5 วินาที (ประตูพังแน่นอน)
            for i = 1, 15 do
                pcall(function()
                    ReplicatedStorage:WaitForChild("__remotes"):WaitForChild("ApartmentService"):WaitForChild("KickApartmentDoor"):InvokeServer(targetDoor)
                end)
                task.wait(0.1)
            end
        end)
        
        warn("✅ กำลังเตะประตู: " .. tostring(targetDoor.Name))
    else
        warn("❌ คุณยืนอยู่ไกลประตูเกินไป กรุณาเดินไปชนหน้าประตูแล้วกดอีกครั้ง")
    end
end

