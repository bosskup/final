        -- Rainbow UI text override
        local hue = tick() % 3 / 3
        local rainbowColor = Color3.fromHSV(hue, 1, 1)
        for _, obj in pairs(char:GetDescendants()) do
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                if string.find(obj.Text, player.Name, 1, true) or string.find(obj.Text, player.DisplayName, 1, true) or string.find(obj.Text, "Hex x hub", 1, true) then
                    obj.Text = "HEX X PREMIUM"
                    obj.TextColor3 = rainbowColor
                    obj.TextStrokeTransparency = 0.2
                    obj.TextStrokeColor3 = Color3.new(0, 0, 0)
                end
            end
        end
    end

    for p, esp in pairs(ESP_Objects) do
        if not Players:FindFirstChild(p.Name) or not ESPEnabled or not isValidTarget(p) or not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            esp.Box.Visible = false
            esp.Text.Visible = false
            esp.Line.Visible = false
            esp.Box:Remove()
            esp.Text:Remove()
            esp.Line:Remove()
            ESP_Objects[p] = nil
        end
    end

    if ESPEnabled then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and isValidTarget(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
                if not ESP_Objects[p] then createESP(p) end
                
                local hrp = p.Character.HumanoidRootPart
                local hum = p.Character.Humanoid
                local rootPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                local esp = ESP_Objects[p]
                
                if onScreen and esp and hum.Health > 0 then
                    local head = p.Character:FindFirstChild("Head")
                    if head then
                        local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                        local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                        
                        local height = math.abs(headPos.Y - legPos.Y)
                        local width = height / 2
                        
                        esp.Box.Size = Vector2.new(width, height)
                        esp.Box.Position = Vector2.new(headPos.X - width / 2, headPos.Y)
                        esp.Box.Visible = true
                        
                        local distance = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)
                        local health = math.floor(hum.Health)
                        local money = getPlayerMoney(p)
                        
                        local icon = TargetMode == "Police" and "👮" or "🔴"
                        local mainColor = TargetMode == "Police" and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(255, 60, 60)
                        
                        esp.Box.Color = mainColor
                        esp.Text.Color = mainColor
                        
                        -- Premium Tracers
                        esp.Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        esp.Line.To = Vector2.new(legPos.X, legPos.Y)
                        esp.Line.Color = mainColor
                        esp.Line.Transparency = 0.5
                        esp.Line.Visible = true
                        
                        esp.Text.Text = string.format("%s %s\nHP: %d | %dm\n$%s", icon, p.Name, health, distance, tostring(money))
                        esp.Text.Position = Vector2.new(headPos.X, headPos.Y - 45)
                        esp.Text.Visible = true
                    end
                else
                    if esp then 
                        esp.Box.Visible = false
                        esp.Text.Visible = false
                        esp.Line.Visible = false 
                    end
                end
            end
        end
    end

    if AimlockEnabled and _G.LockedTarget then
        if not _G.LockedTarget.Character or not _G.LockedTarget.Character:FindFirstChild("HumanoidRootPart") or _G.LockedTarget.Character.Humanoid.Health <= 0 or not isValidTarget(_G.LockedTarget) then
            _G.LockedTarget = nil
            setBtnState(aimMobileBtn, false, {Color3.fromRGB(0, 200, 100), Color3.fromRGB(0, 150, 50)}, {Color3.fromRGB(255, 50, 50), Color3.fromRGB(180, 0, 0)})
            aimMobileBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            aimMobileBtn.Text = "AIM\n(OFF)"
            aimMobileBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(255, 50, 50)
        else
            local targetPart = _G.LockedTarget.Character.HumanoidRootPart
            local targetVelocity = targetPart.AssemblyLinearVelocity
            
            local predictedPosition = targetPart.Position + (targetVelocity * _G.Prediction)
            local screenPos, onScreen = Camera:WorldToViewportPoint(predictedPosition)
            
            local isMobile = UserInputService.TouchEnabled
            
            if mousemoverel and not isMobile then
                if onScreen then
                    local centerPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local deltaX = (screenPos.X - centerPos.X) * _G.AimSmoothness
                    local deltaY = (screenPos.Y - centerPos.Y) * _G.AimSmoothness
                    mousemoverel(deltaX, deltaY)
                end
            else
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, predictedPosition)
                
                -- Force Character Body to turn towards the target so the gun points correctly in 1st person
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = player.Character.HumanoidRootPart
                    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(predictedPosition.X, hrp.Position.Y, predictedPosition.Z))
                end
            end
        end
    end
end)
